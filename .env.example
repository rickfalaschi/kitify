# ===========================================
# Kitify — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Variables marked (required) must be set for the app to start.
# Variables marked (production) are only required in production.

# ---------- Database ----------
DATABASE_URL=                          # (required) Neon PostgreSQL connection string
                                       # Example: postgresql://user:pass@host/dbname?sslmode=require

# ---------- Auth ----------
AUTH_SECRET=                           # (required) Random secret for NextAuth.js sessions
                                       # Generate with: openssl rand -base64 32
AUTH_URL=http://localhost:3000         # (required) Base URL of the app

# ---------- Stripe ----------
STRIPE_SECRET_KEY=                     # (production) Stripe secret key (sk_live_... or sk_test_...)
STRIPE_WEBHOOK_SECRET=                 # (production) Stripe webhook signing secret (whsec_...)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=         # Stripe publishable key (pk_live_... or pk_test_...)

# ---------- Email (SMTP) ----------
SMTP_HOST=                             # (production) SMTP server host
SMTP_PORT=465                          # (production) SMTP server port
SMTP_USER=                             # (production) SMTP username / sender email
SMTP_PASS=                             # (production) SMTP password

# ---------- File Storage (Backblaze B2) ----------
B2_ENDPOINT=                           # (production) S3-compatible endpoint URL
B2_REGION=                             # B2 region (e.g. us-east-005)
B2_BUCKET=                             # (production) Bucket name
B2_KEY_ID=                             # (production) Application key ID
B2_APP_KEY=                            # (production) Application key secret
